# tool-paths.example.env
# Copy to llm-wiki/tool-paths.env and customize for the local machine/project.
# Do not commit secrets.

# Repository/build/install roots
CE_PROJECT_ROOT=
CE_BUILD_ROOT=
CE_INSTALL_ROOT=
CE_PDB_ROOT=
CE_LOG_ROOT=
CE_DUMP_ROOT=
CE_CAPTURE_ROOT=

# Audit tool roots
SECURITY_AUDIT_TOOL_ROOT=
SECURITY_AUDIT_MANIFEST_ROOT=

# Windows optional paths
WINDOWS_SDK_DEBUGGERS_X64=
MSVC_TOOLS_X64=
SYSINTERNALS_ROOT=

# Linux/macOS optional paths
LLVM_ROOT=
CHECKSEC_PATH=
SEMGREP_PATH=
GITLEAKS_PATH=
OSV_SCANNER_PATH=
TRUFFLEHOG_PATH=
FLAWFINDER_PATH=

# Notes:
# - Paths may be absolute or relative to CE_PROJECT_ROOT.
# - The audit should try documented relative discovery before warning.
# - Missing paths should only warn when relevant to the current audit target.
