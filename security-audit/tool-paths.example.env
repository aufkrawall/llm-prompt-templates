# tool-paths.example.env
# Copy to tool-paths.env and customize for the local machine/project.
# Do not commit secrets.

# Repository/build/install roots
CE_PROJECT_ROOT=
CE_BUILD_ROOT=
CE_INSTALL_ROOT=
CE_PDB_ROOT=
CE_LOG_ROOT=
CE_DUMP_ROOT=
CE_CAPTURE_ROOT=

# Audit tool roots
SECURITY_AUDIT_TOOL_ROOT=
SECURITY_AUDIT_MANIFEST_ROOT=

# Windows optional paths
WINDOWS_SDK_DEBUGGERS_X64=
MSVC_TOOLS_X64=
SYSINTERNALS_ROOT=

# Linux/macOS optional paths
LLVM_ROOT=
CHECKSEC_PATH=
SEMGREP_PATH=
GITLEAKS_PATH=
OSV_SCANNER_PATH=
TRUFFLEHOG_PATH=
FLAWFINDER_PATH=

# Notes:
# - Paths may be absolute or relative to CE_PROJECT_ROOT.
# - The audit should try documented relative discovery before warning.
# - Missing paths should only warn when relevant to the current audit target.
# Defaults used by install-security-audit-tools.ps1 on Windows
# SECURITY_AUDIT_TOOL_ROOT=%LOCALAPPDATA%\SecurityAuditTools
# SYSINTERNALS_ROOT=%LOCALAPPDATA%\SecurityAuditTools\bin\sysinternals
# VSWHERE_ROOT=%LOCALAPPDATA%\SecurityAuditTools\bin\vswhere


# Optional strict coverage gate examples
# REQUIRED_AUDIT_TOOLS=semgrep,gitleaks,osv-scanner
# AUDIT_STRICT_REQUIRED_TOOLS=0

# SAST install root used by install-security-audit-tools.ps1
# SAST_TOOL_ROOT=%LOCALAPPDATA%\SecurityAuditTools\bin\sast


# Windows installer behavior toggles
# AUDIT_INSTALL_MINIMAL=0
# AUDIT_SKIP_SAST_INSTALL=0
# AUDIT_SKIP_SECRETS_INSTALL=0
# AUDIT_SKIP_DEPENDENCY_SCANNER_INSTALL=0
# AUDIT_INCLUDE_PYTHON_SAST=0

# Windows full/uninstall examples
# AUDIT_INSTALL_FULL=0
# AUDIT_UNINSTALL=0
# AUDIT_REMOVE_SHARED_PACKAGES=0
# AUDIT_REMOVE_PYTHON_PACKAGES=0
